# Data Go Kr keys
DATA_GO_KR_SERVICE_KEY=YOUR_DATA_GO_KR_KEY
PUBLIC_INST_SERVICE_KEY=YOUR_PUBLIC_INST_KEY
NCS_SERVICE_KEY=YOUR_NCS_KEY

# OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_STRATEGY_TIMEOUT_SEC=60
ENABLE_AI_RERANK=true
OPENAI_NET_CHECK_ENABLED=true
OPENAI_NET_CHECK_STRICT=false
OPENAI_NET_CHECK_CONNECT_TIMEOUT_SEC=5
OPENAI_NET_CHECK_READ_TIMEOUT_SEC=15

# Optional endpoint overrides
PUBLIC_INST_BASE_URL=https://apis.data.go.kr/1051000/public_inst/
NCS_BASE_URL=https://www.ncs.go.kr/api/
NCS_BASE_URLS=https://www.ncs.go.kr/api/

# Authoritative NCS source for the interview MVP
NCS_MCP_URL=http://127.0.0.1:8778/mcp
NCS_MCP_TIMEOUT_SEC=45
KORDOC_OCR=true
MAX_UPLOAD_MB=30
ENABLE_LEGACY_NCS_API=false

# Database
DATABASE_URL=sqlite:///./payroll2.db

# Admin
ADMIN_TOKEN=SET_STRONG_ADMIN_TOKEN
ENABLE_ADMIN_ENDPOINTS=false

# Auto-run options
AUTO_SYNC_PUBLIC_INST=false
AUTO_SYNC_NCS=false
AUTO_USE_OPENAI_IN_REPORT=true
SYNC_INTERVAL_MINUTES=60
NCS_SYNC_PATH=Ncs1info/ncsinfo.do
