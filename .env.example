# NCScope MVP runtime
# Copy this file to `.env` for local development.

# FastAPI imports do not auto-load `.env` by default.
# Use `.\run_local.ps1`, export variables in the shell, or set this true only for
# trusted single-process local development.
NCSCOPE_LOAD_DOTENV=false

# Required: read-only NCS_MCP endpoint backed by the compact serving DB.
NCS_MCP_URL=http://127.0.0.1:8778/mcp
NCS_MCP_TIMEOUT_SEC=45

# Required for AI-generated interview questions.
# You can also leave this empty and enter a request-scoped key in the UI.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_STRATEGY_TIMEOUT_SEC=60
ENABLE_AI_RERANK=true
OPENAI_NET_CHECK_ENABLED=true
OPENAI_NET_CHECK_STRICT=false
OPENAI_NET_CHECK_CONNECT_TIMEOUT_SEC=5
OPENAI_NET_CHECK_READ_TIMEOUT_SEC=15

# Upload and parser behavior.
MAX_UPLOAD_MB=30
KORDOC_OCR=true

# Small local app DB. This is not the NCS serving DB.
DATABASE_URL=sqlite:///./ncscope.db

# Keep public/admin/legacy maintenance surfaces disabled for the MVP.
ENABLE_ADMIN_ENDPOINTS=false
ADMIN_TOKEN=SET_STRONG_ADMIN_TOKEN
ENABLE_LEGACY_NCS_API=false
AUTO_SYNC_PUBLIC_INST=false
AUTO_SYNC_NCS=false

# Legacy public-data integrations are not used by the default NCScope MVP path.
# Enable only for private maintenance deployments that intentionally reactivate
# legacy endpoints.
# PUBLIC_INST_SERVICE_KEY=YOUR_PUBLIC_INST_KEY
# NCS_SERVICE_KEY=YOUR_NCS_KEY
# PUBLIC_INST_BASE_URL=https://apis.data.go.kr/1051000/public_inst/
# NCS_BASE_URL=https://www.ncs.go.kr/api/
# NCS_BASE_URLS=https://www.ncs.go.kr/api/
